# Local auth key for Claude Code -> Claude Code Router
# Change this before running.
CCR_APIKEY=change-me-local-router-secret

# Provider keys. Fill only the providers you will use.
ZAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# Runtime options
LOG_LEVEL=debug
API_TIMEOUT_MS=600000
